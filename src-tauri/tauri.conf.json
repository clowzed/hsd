{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Честный Знак Сканер",
  "identifier": "com.honest-sign.scanner",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Честный Знак Сканер",
        "width": 900,
        "height": 650,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  }
}
