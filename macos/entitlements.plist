<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow USB device access for barcode scanner -->
    <key>com.apple.security.device.usb</key>
    <true/>

    <!-- Allow serial port access -->
    <key>com.apple.security.device.serial</key>
    <true/>

    <!-- Allow audio output for feedback sounds -->
    <key>com.apple.security.device.audio-input</key>
    <false/>

    <!-- Network access for CRPT API -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- File access for PDF output -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow app to run without sandboxing for USB access -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
